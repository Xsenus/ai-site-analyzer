# --- OpenAI / Embeddings ---
OPENAI_API_KEY=sk-***your_key***
CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large
VECTOR_DIM=3072

# --- Внутренний сервис эмбеддингов (опционально) ---
INTERNAL_EMBED_URL=
INTERNAL_EMBED_TIMEOUT=6.0

# --- AI Search ---
AI_SEARCH_TIMEOUT=12.0
AI_SEARCH_RATE_LIMIT_PER_MIN=10

# --- CORS (optional) ---
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# --- Logging ---
LOG_LEVEL=INFO

# --- Отладочные флаги эмбеддингов (опционально) ---
EMBED_PREVIEW_CHARS=160
EMBED_BATCH_SIZE=96
EMBED_MAX_CHARS=200000
DEBUG_OPENAI_LOG=false

# --- Billing / Costs API (опционально) ---
# Нужен admin key организации для /v1/organization/costs
OPENAI_ADMIN_KEY=
BILLING_MONTHLY_LIMIT_USD=
BILLING_PREPAID_CREDITS_USD=
BILLING_COSTS_BASE_URL=https://api.openai.com/v1
BILLING_SUMMARY_CACHE_TTL_SEC=300

# --- Monitoring / rollout helpers (optional) ---
AI_SITE_ANALYZER_HEALTHCHECK_BASE_URL=http://127.0.0.1:8123
AI_SITE_ANALYZER_HEALTHCHECK_HEALTH_URL=
AI_SITE_ANALYZER_HEALTHCHECK_BILLING_URL=
AI_SITE_ANALYZER_HEALTHCHECK_TIMEOUT=10
AI_SITE_ANALYZER_HEALTHCHECK_STATE_FILE=/var/lib/ai-site-analyzer/system-health-state.json
AI_SITE_ANALYZER_HEALTHCHECK_ARTIFACT_DIR=/var/lib/ai-site-analyzer/system-health
AI_SITE_ANALYZER_HEALTHCHECK_ARTIFACT_RETENTION=14
AI_SITE_ANALYZER_HEALTHCHECK_ALERT_WEBHOOK_URL=
AI_SITE_ANALYZER_HEALTHCHECK_ALERT_ON_RECOVERY=true
