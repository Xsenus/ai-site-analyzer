# Shared monitoring configuration for ai-site-analyzer systemd helpers.

AI_SITE_ANALYZER_HEALTHCHECK_BASE_URL=http://127.0.0.1:8123
AI_SITE_ANALYZER_HEALTHCHECK_HEALTH_URL=
AI_SITE_ANALYZER_HEALTHCHECK_BILLING_URL=
AI_SITE_ANALYZER_HEALTHCHECK_TIMEOUT=10
AI_SITE_ANALYZER_HEALTHCHECK_STATE_FILE=/var/lib/ai-site-analyzer/system-health-state.json
AI_SITE_ANALYZER_HEALTHCHECK_ARTIFACT_DIR=/var/lib/ai-site-analyzer/system-health
AI_SITE_ANALYZER_HEALTHCHECK_ALERT_WEBHOOK_URL=
AI_SITE_ANALYZER_HEALTHCHECK_ALERT_ON_RECOVERY=true
